Options -Indexes
DirectoryIndex index.html

# Block direct access to JSON data files
<FilesMatch "\.json$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>

# PHP session hardening
<IfModule mod_php.c>
  php_value session.cookie_httponly 1
  php_value session.use_strict_mode 1
</IfModule>
<IfModule mod_php8.c>
  php_value session.cookie_httponly 1
  php_value session.use_strict_mode 1
</IfModule>

# Allow all other requests
<IfModule mod_authz_core.c>
  Require all granted
</IfModule>
<IfModule !mod_authz_core.c>
  Allow from all
</IfModule>
